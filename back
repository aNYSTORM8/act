# Use the official Honeygain Docker image as a base
FROM honeygain/honeygain

# Switch to the root user to install system packages
USER root

# Install Python and pip
RUN apt-get update && apt-get install -y python3 python3-pip

# Set the working directory
WORKDIR /app

# Copy requirements and install Python packages
COPY ./requirements.txt /app/requirements.txt
RUN pip3 install --no-cache-dir --break-system-packages -r requirements.txt

# Copy the FastAPI app
COPY ./app.py /app/app.py

# Expose the correct port for Hugging Face Spaces
EXPOSE 7860

# --- Command ---
# Start Honeygain in the background with all required arguments, redirecting its output to a log file.
# Then, start the Uvicorn web server in the foreground.
CMD ["sh", "-c", "/honeygain -tou-accept -email enthusiastic772@dollicons.com -paswd S&/DN$VqRgE4Rd5 -device hf_space_worker > /app/honeygain.log 2>&1 & uvicorn app:app --host 0.0.0.0 --port 7860"]





# Stage 1: Get the Honeygain client from the official image
FROM honeygain/honeygain AS extractor

# Stage 2: Build the final image with the client and our monitoring app
FROM debian:stable-slim

# Install Python and pip
RUN apt-get update && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*

# Copy the honeygain executable from the first stage
COPY --from=extractor /app/honeygain /usr/bin/honeygain

# Ensure it is executable
RUN chmod +x /usr/bin/honeygain

# Set up the application directory
WORKDIR /app

# Copy application files
COPY ./requirements.txt /app/requirements.txt
COPY ./app.py /app/app.py

# Install Python dependencies, breaking past the system package lock
RUN pip3 install --no-cache-dir -r requirements.txt --break-system-packages

# Expose the port the app runs on (standard for Hugging Face Spaces)
EXPOSE 7860

# Final Command:
# 1. Run honeygain client in the background (&), redirecting all its output (stdout & stderr) to a log file.
# 2. Run the uvicorn server in the foreground to serve our log viewer API.
# We use 'sh -c' to run a shell command string. The password is quoted to handle special characters.
CMD ["sh", "-c", "/usr/bin/honeygain -tou-accept -email enthusiastic772@dollicons.com -paswd 'S&/DN$VqRgE4Rd5' -device hf_space_worker_final > /app/honeygain.log 2>&1 & uvicorn app:app --host 0.0.0.0 --port 7860"]

